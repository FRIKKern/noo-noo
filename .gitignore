# Go
*.exe
*.test
*.prof
*.out
/bin/
/dist/

# Wails (added in v0.3) — ignore compiled app bundles produced by `wails3 build`.
# The pattern is path-anchored (no leading slash but applied per-directory)
# so it only catches `build/` directories that aren't explicitly re-included
# below. Source-tree build/ under cmd/noo-noo-app/ (appicon + Wails inputs)
# AND under repo root (Phase 0.4 release scripts + brew templates) stay
# committed — those are inputs, not outputs.
build/
!build/
!build/release/
!build/release/**
!build/brew/
!build/brew/**
!cmd/noo-noo-app/build/
!cmd/noo-noo-app/build/**
frontend/dist/
frontend/node_modules/
frontend/.svelte-kit/
cmd/noo-noo-app/frontend/dist/
cmd/noo-noo-app/frontend/node_modules/

# Node
node_modules/
npm-debug.log*

# IDE
.vscode/
.idea/
*.swp

# macOS
.DS_Store

# Local dev artifacts
*.db
*.db-journal
.env
.env.local
.verify-blocked
verification-results/
